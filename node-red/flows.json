    {
        "id": "f0a8cfb4430d2072",
        "type": "function",
        "z": "e3ca88df1a09ceff",
        "d": true,
        "name": "function 3",
        "func": "// ksqlDB response example:\n// [\n//   { header: {...} },\n//   { row: { columns: [...] } },\n//   { row: { columns: [...] } }\n// ]\n\nconst rows = msg.payload || [];\nconst result = [];\n\nfor (const r of rows) {\n\n    // ✅ skip schema/header/invalid messages\n    if (!r || !r.row || !Array.isArray(r.row.columns)) continue;\n\n    const c = r.row.columns;\n\n    // DEBUG (optional - remove later)\n    // node.warn(c);\n\n    /*\n      IMPORTANT:\n      Because you are using MATERIALIZED TABLE,\n      first column = TABLE KEY (city)\n\n      So actual order becomes:\n\n      c[0] = key_city\n      c[1] = order_id\n      c[2] = order_date\n      c[3] = buyer_name\n      c[4] = city\n      c[5] = state\n      c[6] = sku\n      c[7] = description\n      c[8] = quantity\n      c[9] = amount\n      c[10] = event_time\n    */\n\n    result.push({\n    order_id: c[0],\n    buyer_name: c[1],\n    city: c[2],\n    state: c[3],\n    order_date: c[4],\n    sku: c[5],\n    description: c[6],\n    quantity: Number(c[7]),\n    amount: Number(c[8]),\n    event_time: c[9] ? Number(c[9]) : null\n});\n}\n\n// send clean array to React\nmsg.payload = result;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
