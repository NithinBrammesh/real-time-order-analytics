        "id": "de33e8dae38a2bc6",
        "type": "function",
        "z": "e3ca88df1a09ceff",
        "name": "JSON Formatter",
        "func": "// =========================\n// 🔹 JSON FORMATTER (FINAL)\n// =========================\n\n// Ensure payload is object\nif (typeof msg.payload !== \"object\") {\n    node.warn(\"Invalid payload: \" + msg.payload);\n    return null;\n}\n\nconst row = msg.payload;\n\n// ---- Clean Order ID ----\nconst orderId = row.order_no ? row.order_no.toString().trim() : null;\n\n// ---- Clean City ----\nconst city = row.ship_city\n    ? row.ship_city.replace(/,+$/, '').trim().toUpperCase()\n    : null;\n\n// ---- Clean Amount ----\nlet amount = null;\nif (row.item_total) {\n    amount = Number(\n        row.item_total.toString().replace(/[₹,]/g, '')\n    );\n}\n\n// ---- Validation ----\nif (!orderId || !city) {\n    node.warn(\"Skipping invalid row: \" + JSON.stringify(row));\n    return null;\n}\n\n// =========================\n// 🔹 FINAL JSON OUTPUT\n// =========================\n\nmsg.payload = {\n    order_id: orderId,\n    amount: amount !== null ? amount : 0,\n    city: city\n};\n\n// Debug\nnode.warn(\"FINAL JSON → \" + JSON.stringify(msg.payload));\n\nreturn msg;",
