    {
        "id": "51d2c0d01d3b4082",
        "type": "function",
        "z": "e3ca88df1a09ceff",
        "d": true,
        "name": "function 1",
        "func": "// =========================\n// 🔹 CLEAN & PREPARE DATA\n// =========================\n\n// ---- Clean date ----\nconst rawDate = msg.payload.order_date || \"\";\n\nconst cleanedDate = rawDate\n  .replace(/^[A-Za-z]+,\\s*/, '')\n  .replace(/\\sIST$/, '');\n\nconst parsedDate = new Date(cleanedDate + ' GMT+0530');\nconst eventTime = isNaN(parsedDate.getTime()) ? null : parsedDate.getTime();\n\n// ---- Clean city & state ----\nconst cleanCity = msg.payload.ship_city\n  ? msg.payload.ship_city.replace(/,+$/, '').trim().toUpperCase()\n  : null;\n\nconst cleanState = msg.payload.ship_state\n  ? msg.payload.ship_state.replace(/,+$/, '').trim().toUpperCase()\n  : null;\n\n// ---- Clean amount (₹, commas) ----\nconst cleanAmount = msg.payload.item_total\n  ? Number(msg.payload.item_total.toString().replace(/[₹,]/g, ''))\n  : null;\n\n// ---- Build normalized object ----\nconst order = {\n  order_id: msg.payload.order_no || null,\n  order_date: rawDate,\n  buyer_name: msg.payload.buyer || null,\n  city: cleanCity,\n  state: cleanState,\n  sku: msg.payload.sku || null,\n  description: msg.payload.description || null,\n  quantity: msg.payload.quantity ? Number(msg.payload.quantity) : null,\n  amount: cleanAmount,\n  event_time: eventTime\n};\n\n\n// =========================\n// 🔹 FORMAT SWITCH (IMPORTANT)\n// =========================\n\nlet format = msg.format || \"json\";  // default json\n\ntry {\n\n  if (format === \"csv\") {\n    // CSV format: order_id,amount,city\n    msg.payload = `${order.order_id},${order.amount},${order.city}`;\n  }\n\n  else if (format === \"xml\") {\n    // XML format\n    msg.payload = `<order>\n  <order_id>${order.order_id}</order_id>\n  <amount>${order.amount}</amount>\n  <city>${order.city}</city>\n</order>`;\n  }\n\n  else {\n    // JSON format (default)\n    msg.payload = JSON.stringify({\n      order_id: order.order_id,\n      amount: order.amount,\n      city: order.city\n    });\n  }\n\n} catch (err) {\n  node.error(\"Format conversion error: \" + err);\n  return null;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
