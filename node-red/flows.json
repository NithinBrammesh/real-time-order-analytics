    {
        "id": "ecdd85a6f56c6f28",
        "type": "function",
        "z": "e3ca88df1a09ceff",
        "d": true,
        "name": "function 2",
        "func": "const city = (msg.req.query.city || \"BENGALURU\").toUpperCase();\nconst name = (msg.req.query.name || \"\").toUpperCase();\nconst limit = parseInt(msg.req.query.limit || \"10\", 10);\n\nlet query = `\nSELECT\n   order_id,\n   order_date,\n   buyer_name,\n   city,\n   state,\n   sku,\n   description,\n   quantity,\n   amount,\n   event_time\nFROM ORDERS_BY_CITY_NAME\nWHERE city='${city}'\n`;\n\nif (name) {\n    query += ` AND buyer_name='${name}'`;\n}\n\nquery += ` LIMIT ${limit};`;\n\nmsg.payload = { ksql: query };\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
