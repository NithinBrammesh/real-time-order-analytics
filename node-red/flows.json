        "z": "e3ca88df1a09ceff",
        "name": "CSV Formatter",
        "func": "// =========================\n// 🔹 FINAL CSV FORMATTER (CLEAN + SAFE)\n// =========================\n\n// Ensure payload is object\nif (typeof msg.payload !== \"object\") {\n  node.warn(\"Invalid payload (not object): \" + msg.payload);\n  return null;\n}\n\nconst row = msg.payload;\n\n// ---- Clean date ----\nconst rawDate = row.order_date || \"\";\n\nconst cleanedDate = rawDate\n  .replace(/^[A-Za-z]+,\\s*/, '')\n  .replace(/\\sIST$/, '');\n\n//timezone\nconst parsedDate = new Date(cleanedDate + ' GMT+0530');\nconst eventTime = isNaN(parsedDate.getTime()) ? null : parsedDate.getTime();\n\n// ---- Clean city ----\nconst cleanCity = row.ship_city\n  ? row.ship_city.replace(/,+$/, '').trim().toUpperCase()\n  : null;\n\n// ---- Clean state ----\nconst cleanState = row.ship_state\n  ? row.ship_state.replace(/,+$/, '').trim().toUpperCase()\n  : null;\n\n// ---- Clean amount ----\nconst cleanAmount = row.item_total\n  ? Number(row.item_total.toString().replace(/[₹,]/g, ''))\n  : null;\n\n// ---- Validate required fields ----\nif (!row.order_no || !cleanCity) {\n  node.warn(\"Skipping invalid row: \" + JSON.stringify(row));\n  return null;\n}\n\n// ---- Build object ----\nconst order = {\n  order_id: row.order_no,\n  order_date: rawDate,\n  buyer_name: row.buyer || null,\n  city: cleanCity,\n  state: cleanState,\n  sku: row.sku || null,\n  description: row.description || null,\n  quantity: row.quantity ? Number(row.quantity) : null,\n  amount: cleanAmount,\n  event_time: eventTime\n};\n\n// =========================\n// 🔹 CSV OUTPUT\n// =========================\n// Format: order_id,amount,city\n\nconst amountFinal = order.amount !== null ? order.amount : 0;\n\nmsg.payload = `${order.order_id},${amountFinal},${order.city}`;\n\n// Debug log\nnode.warn(\"FINAL CSV → \" + msg.payload);\n\nreturn msg;",
