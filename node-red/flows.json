    {
        "id": "8c941676ccb64104",
        "type": "function",
        "z": "e3ca88df1a09ceff",
        "name": "function websocket format",
        "func": "// 1. Ensure payload exists\nif (!msg.payload) {\n    return null;\n}\n\nlet data;\n\n// 2. Safely parse JSON\ntry {\n    data = (typeof msg.payload === \"string\")\n        ? JSON.parse(msg.payload)\n        : msg.payload;\n} catch (err) {\n    node.warn(\"❌ Invalid JSON received from Kafka\");\n    return null;\n}\n\n// 3. Validate required fields\nif (\n    !data.city ||\n    typeof data.total_amount !== \"number\" ||\n    typeof data.count !== \"number\" ||\n    typeof data.avg !== \"number\"\n) {\n    node.warn(\"⚠️ Invalid data format received\");\n    return null;\n}\n\n// 4. Normalize\ndata.city = String(data.city).toUpperCase();\n\nconst cleanData = {\n    city: data.city,\n    total_amount: data.total_amount,\n    count: data.count,\n    avg: data.avg\n};\n\n\n// 🔥 5. STORE DATA (THIS IS THE IMPORTANT PART)\nlet current = global.get(\"orders\") || [];\n\n// remove old entry for same city\ncurrent = current.filter(o => o.city !== cleanData.city);\n\n// add updated one\ncurrent.push(cleanData);\n\n// save back\nglobal.set(\"orders\", current);\n\n\n// 🔥 6. Send to WebSocket\nmsg.payload = cleanData;\n\nreturn msg;",
