        "z": "e3ca88df1a09ceff",
        "d": true,
        "name": "",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:8088/query",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
